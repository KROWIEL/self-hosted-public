# ============================================================
# Self-Hosted PaaS — example environment
# Copy to .env and fill in. Never commit the real .env.
# ============================================================

# --- Control plane (NestJS) ---
NODE_ENV=development
CP_PORT=3001

# PostgreSQL (managed by Drizzle ORM)
DATABASE_URL=postgresql://selfhosted:selfhosted@localhost:5432/selfhosted?sslmode=disable

# Redis (BullMQ build queue)
REDIS_URL=redis://localhost:6379

# JWT for user sessions (panel UI -> control plane).
# The dev launcher (start.ps1 / start.sh) replaces these change-me placeholders
# with strong random values on first run. The control plane REFUSES to start
# with a missing, <32-char, or "change-me"/default secret, so for production set
# your own strong values (e.g. `openssl rand -base64 48`).
JWT_SECRET=change-me-access-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Dedicated secret for signing deploy-webhook tokens. Keep it SEPARATE from the
# JWT secrets so rotating one never invalidates the other. Required in production
# (startup fails without it); the dev launcher generates one automatically.
# Generate: openssl rand -base64 32
WEBHOOK_SECRET=change-me-webhook-secret

# Master key for AES-256-GCM encryption of secrets at rest
# (PATs, env secrets, daemon tokens). 32 bytes, base64-encoded.
# The dev launcher generates this automatically on first run; for production
# generate your own: openssl rand -base64 32
ENCRYPTION_KEY=change-me-32-byte-base64-key

# Private key (PEM) used by control plane to sign JWTs sent to agents.
# Generate a keypair; agents store the matching public key.
AGENT_JWT_PRIVATE_KEY_PATH=./secrets/agent-jwt-private.pem

# Dev only: let the control plane reach a local agent over plain HTTP
# (instead of https). Set to 1 when running the agent on localhost without TLS.
AGENT_INSECURE_HTTP=0

# Dev only: allow starting/stopping the local Go agent from the UI. The control
# plane spawns `go run ./cmd/agent` (or AGENT_BINARY) with the node's token.
# NEVER enable in production — it lets the API spawn local processes.
LOCAL_AGENT_ENABLED=0
# Optional overrides for the local agent launcher:
# AGENT_LOCAL_DIR=/abs/path/to/services/agent
# AGENT_BINARY=/abs/path/to/agent.exe

# First-run admin seeded by `npm run db:seed`.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Self-service registration (public POST /auth/register). OFF by default so a
# fresh panel is not open to anonymous account creation — the seeded admin and
# SSO sign-in are unaffected. Set to 1/true to allow public sign-up.
ALLOW_OPEN_REGISTRATION=0

# Auto-rotate each node's long-lived daemon token after this many days
# (confirmation-gated: agent must accept the new secret first). Default 30.
# Set to 0 to disable scheduled rotation (manual POST /nodes/:id/rotate-token
# still works). Optional check cadence: DAEMON_TOKEN_ROTATION_CHECK_MS (1h).
DAEMON_TOKEN_ROTATION_DAYS=30

# --- Commercial licensing (optional) ---
# The panel is open-core: the free tier is unlimited. Paid tiers (Home-Lab, Pro)
# unlock add-on modules (e.g. Reverse-tunnels) via a signed license key.
#
# Preferred: activate a key in the UI (Billing → License key, admin only) — it is
# stored in the database. Alternatively pin a key here for immutable deployments:
# LICENSE_KEY=
#
# Override the verification public key (PEM) if you generated your own signing
# keypair. Full PEM, or one line with \n:
# LICENSE_PUBLIC_KEY=
#
# Online activation (optional). When set, paid modules require a recent
# successful heartbeat against your activation server; without contact they lock
# after the grace window. Leave empty for offline / key-only mode.
# LICENSE_ACTIVATION_URL=https://activate.your-domain.com/activate
# LICENSE_HEARTBEAT_INTERVAL_MS=21600000     # how often to check (default 6h)
# LICENSE_ACTIVATION_MAX_AGE_MS=259200000    # lock paid modules if no success within (default 72h)

# Email used by Traefik for Let's Encrypt certificate registration.
ACME_EMAIL=admin@example.com

# Subdomain TLS (pick one approach):
#
# A) HTTP-01 (default, no extra config): add a wildcard DNS record
#    *.yourdomain.com → VDS IP. Traefik issues a cert per subdomain on first
#    HTTPS visit (resolver: letsencrypt).
#
# B) DNS-01 wildcard cert (*.yourdomain.com + yourdomain.com in one cert):
#    1. Point DNS to Cloudflare (or set ACME_DNS_PROVIDER in docker-compose).
#    2. Create a Cloudflare API token with Zone:DNS:Edit for the domain.
#    3. Set CLOUDFLARE_DNS_API_TOKEN below and ACME_WILDCARD_CERTS=1 on the agent.
#    4. Restart Traefik (docker compose up -d traefik) and redeploy services.
ACME_WILDCARD_CERTS=0
# ACME_CERT_RESOLVER=letsencrypt-dns
# CLOUDFLARE_DNS_API_TOKEN=
# ACME_DNS_PROVIDER=cloudflare

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# --- Single sign-on / OIDC (Pro: sso) ---
# Externally reachable base URLs, used to build the OIDC redirect and to bounce
# the browser back to the panel after sign-in. Only needed when SSO is enabled
# and the panel runs behind a domain/reverse proxy (otherwise sensible localhost
# defaults are used). The OIDC redirect URI you register at your identity
# provider is: ${PUBLIC_API_URL}/auth/sso/callback
# PUBLIC_API_URL=https://panel.yourdomain.com/api/v1
# APP_BASE_URL=https://panel.yourdomain.com

# Checkout URLs shown on the Billing page. Point these at your store
# (e.g. the self-hosted-pay service). Fallbacks point to placeholders if unset.
# NEXT_PUBLIC_BUY_HOMELAB_URL=https://sh.m2by.ru/buy?tier=homelab
# NEXT_PUBLIC_BUY_PRO_URL=https://sh.m2by.ru/buy?tier=pro

# --- Agent (Go daemon) — used on each node, not by the panel ---
AGENT_PORT=8443
AGENT_TLS_CERT=/etc/self-hosted-agent/cert.pem
AGENT_TLS_KEY=/etc/self-hosted-agent/key.pem
# Public key (PEM) matching control plane's signing key, to verify incoming JWTs
AGENT_JWT_PUBLIC_KEY_PATH=/etc/self-hosted-agent/agent-jwt-public.pem
# Shared registration token issued by the panel when the node is created
# (returned once as `daemonTokenPlaintext` by POST /api/v1/nodes).
AGENT_DAEMON_TOKEN=change-me-daemon-token
# Where the agent clones repos during builds (prefer tmpfs in prod).
AGENT_WORKDIR=/tmp/agent-builds
# Docker network deployed service containers join. Use the shared edge network
# (created by docker-compose) so Traefik can route to them by domain.
AGENT_NETWORK=selfhosted-edge
# Root of the Dockerfile templates shipped with the agent.
AGENT_TEMPLATES_DIR=/opt/agent/templates
# Dev only: publish deployed service ports to the host so apps are reachable at
# localhost:<port> without a reverse proxy. Leave 0 in production (use Traefik).
AGENT_PUBLISH_PORTS=0
