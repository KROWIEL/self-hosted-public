# Agent configuration (set on each node).
AGENT_PORT=8443
# Token issued by the control plane when registering this node.
AGENT_DAEMON_TOKEN=
# Where repos are cloned during builds (prefer tmpfs in production).
AGENT_WORKDIR=/tmp/agent-builds
# Default Docker network deployed services join.
AGENT_NETWORK=bridge
# Directory containing stack Dockerfile templates shipped with the agent.
AGENT_TEMPLATES_DIR=/opt/agent/templates
